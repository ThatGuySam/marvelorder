---
import HeadCommon from '../components/HeadCommon.astro';
import GoogleAnalytics from '../components/meta/google-analytics.astro';
import HeadScript from '~/src/components/head-script.astro'
import HeadStyles from '~/src/components/head-styles.astro'
import HeadSEO from '../components/HeadSEO.astro';
import Header from '../components/Header/Header.astro';
import Footer from '../components/Footer/Footer.astro';
import PageContent from '../components/PageContent/PageContent.astro';
import LeftSidebar from '../components/LeftSidebar/LeftSidebar.astro';
import RightSidebar from '../components/RightSidebar/RightSidebar.astro';
import { expandImagePathPlaceholders } from '../helpers/image-paths';
import * as CONFIG from '../config';

const content = expandImagePathPlaceholders( Astro.props.content ?? {} );
const currentPage = new URL(Astro.request.url).pathname;
const currentFile = `src/pages${currentPage.replace(/\/$/, '')}.md`;
const githubEditUrl = CONFIG.GITHUB_EDIT_URL && CONFIG.GITHUB_EDIT_URL + currentFile;
---

<html dir={content.dir ?? 'ltr'} lang={content.lang ?? 'en-us'} class="initial">
	<head>
		<HeadCommon />
        <GoogleAnalytics />
        <HeadStyles />
        <HeadScript />
		<HeadSEO {content} canonicalURL={Astro.url} />
		<title>{content.title ? `${content.title} 🚀 ${CONFIG.SITE.title}` : CONFIG.SITE.title}</title>
		<style>
			body.main-layout {
				width: 100%;
				/* display: grid; */
				/* grid-template-rows: var(--theme-navbar-height) 1fr; */
				--gutter: 0.5rem;
				--doc-padding: 2rem;
			}
			.layout {
				display: grid;
				grid-auto-flow: column;
				grid-template-columns:
					minmax(var(--gutter), 1fr)
					minmax(0, var(--max-width))
					minmax(var(--gutter), 1fr);
				overflow-x: hidden;
			}
			.layout :global(> *) {
				width: 100%;
				height: 100%;
			}
			.grid-sidebar {
				height: 100vh;
				position: sticky;
				top: 0;
				padding: 0;
			}
			#grid-left {
				position: fixed;
				z-index: 10;
				display: none;
			}
			#grid-main {
				padding: var(--doc-padding) var(--gutter);
				grid-column: 2;
				display: flex;
				flex-direction: column;
				height: 100%;
			}
			#grid-right {
				display: none;
			}
			:global(.mobile-sidebar-toggle) {
				overflow: hidden;
			}
			:global(.mobile-sidebar-toggle) #grid-left {
				display: block;
				top: 2rem;
			}
			@media (min-width: 50em) {
				.layout {
					overflow: initial;
					grid-template-columns:
						20rem
						minmax(0, var(--max-width));
					gap: 1em;
				}
				#grid-left {
					display: flex;
					padding-left: 2rem;
					position: sticky;
					grid-column: 1;
				}
			}

			@media (min-width: 72em) {
				.layout {
					grid-template-columns:
						20rem
						minmax(0, var(--max-width))
						18rem;
					padding-left: 0;
					padding-right: 0;
					margin: 0 auto;
				}
				#grid-right {
					grid-column: 3;
					display: flex;
				}
			}
		</style>
	</head>

	<body class="main-layout theme-dark">
		<Header {currentPage} />
		<main class="layout min-h-screen">
			<aside
				id="grid-left"
				class="grid-sidebar backdrop-blur bg-black/25"
				title="Site Navigation"
			>
				<LeftSidebar {currentPage} />
			</aside>
			<div id="grid-main">
				<PageContent {content} {githubEditUrl}>
					<slot />
				</PageContent>
			</div>
			<aside id="grid-right" class="grid-sidebar" title="Table of Contents">
				<RightSidebar {content} {githubEditUrl} />
			</aside>
		</main>

		<Footer {content} />

		<script
			is:inline
			define:vars={{
				defaultWorkerImageOrigin: CONFIG.IMAGE_WORKER_ORIGIN,
				netlifyFanartImagePath: CONFIG.NETLIFY_FANART_IMAGE_PATH,
				netlifyFunctionsPathPrefix: CONFIG.NETLIFY_FUNCTIONS_PATH_PREFIX,
				netlifyTmdbImagePath: CONFIG.NETLIFY_TMDB_IMAGE_PATH,
			}}
		>
			const workerImagesParam = new URL( window.location.href ).searchParams.get( 'worker-images' )
			const truthyValues = new Set( [ '', '1', 'true', 'yes', 'on' ] )

			function escapeRegExp ( value ) {
				return value.replace( /[.*+?^${}()|[\]\\]/g, '\\$&' )
			}

			const absoluteImagePathPattern = new RegExp(
				`^https?:\\/\\/[^/]+(${ escapeRegExp( netlifyFunctionsPathPrefix ) }\\/(?:tmdb-image|fanart)\\/.*)$`,
				'i',
			)

			function normalizeWorkerOrigin ( value ) {
				if ( !value ) {
					return ''
				}

				try {
					return new URL( value ).origin
				}
				catch {
					return value.replace( /\/$/, '' )
				}
			}

			function getWorkerOrigin () {
				if ( workerImagesParam === null ) {
					return ''
				}

				if ( truthyValues.has( workerImagesParam.toLowerCase() ) ) {
					return normalizeWorkerOrigin( defaultWorkerImageOrigin )
				}

				return normalizeWorkerOrigin( workerImagesParam )
			}

			function getImagePathKind ( value ) {
				if ( value.startsWith( netlifyTmdbImagePath ) ) {
					return 'tmdb'
				}

				if ( value.startsWith( netlifyFanartImagePath ) ) {
					return 'fanart'
				}

				return ''
			}

			function makeWorkerImagePath ( workerOrigin, imagePathKind ) {
				return imagePathKind === 'fanart'
					? `${ workerOrigin }${ netlifyFanartImagePath }`
					: `${ workerOrigin }${ netlifyTmdbImagePath }`
			}

			function rewriteImageUrl ( value, workerOrigin ) {
				if ( !value ) {
					return value
				}

				const absoluteMatch = value.match( absoluteImagePathPattern )
				const normalizedValue = absoluteMatch ? absoluteMatch[ 1 ] : value
				const imagePathKind = getImagePathKind( normalizedValue )

				if ( !imagePathKind ) {
					return value
				}

				const netlifyImagePath = imagePathKind === 'fanart'
					? netlifyFanartImagePath
					: netlifyTmdbImagePath
				const rewrittenPrefix = makeWorkerImagePath( workerOrigin, imagePathKind )

				return `${ rewrittenPrefix }${ normalizedValue.slice( netlifyImagePath.length ) }`
			}

			function rewriteSrcSet ( value, workerOrigin ) {
				if ( !value ) {
					return value
				}

				return value
					.split( ',' )
					.map( ( item ) => {
						const trimmed = item.trim()

						if ( !trimmed ) {
							return trimmed
						}

						const [ imageUrl, descriptor ] = trimmed.split( /\s+/, 2 )
						const rewrittenUrl = rewriteImageUrl( imageUrl, workerOrigin )

						return descriptor ? `${ rewrittenUrl } ${ descriptor }` : rewrittenUrl
					} )
					.join( ', ' )
			}

			function rewriteElementAttributes ( element, workerOrigin ) {
				for ( const attributeName of [ 'src', 'data-src', 'poster' ] ) {
					const value = element.getAttribute( attributeName )
					const rewrittenValue = rewriteImageUrl( value, workerOrigin )

					if ( value && rewrittenValue !== value ) {
						element.setAttribute( attributeName, rewrittenValue )
					}
				}

				for ( const attributeName of [ 'srcset', 'data-srcset' ] ) {
					const value = element.getAttribute( attributeName )
					const rewrittenValue = rewriteSrcSet( value, workerOrigin )

					if ( value && rewrittenValue !== value ) {
						element.setAttribute( attributeName, rewrittenValue )
					}
				}
			}

			function rewriteNodeTree ( node, workerOrigin ) {
				if ( !( node instanceof Element ) ) {
					return
				}

				rewriteElementAttributes( node, workerOrigin )

				for ( const element of node.querySelectorAll( '[src], [data-src], [poster], [srcset], [data-srcset]' ) ) {
					rewriteElementAttributes( element, workerOrigin )
				}
			}

			const workerOrigin = getWorkerOrigin()

			if ( workerOrigin ) {
				rewriteNodeTree( document.documentElement, workerOrigin )

				const observer = new MutationObserver( ( mutations ) => {
					for ( const mutation of mutations ) {
						if ( mutation.type === 'attributes' && mutation.target instanceof Element ) {
							rewriteElementAttributes( mutation.target, workerOrigin )
							continue
						}

						if ( mutation.type === 'childList' ) {
							for ( const node of mutation.addedNodes ) {
								rewriteNodeTree( node, workerOrigin )
							}
						}
					}
				} )

				observer.observe( document.documentElement, {
					subtree: true,
					childList: true,
					attributes: true,
					attributeFilter: [ 'src', 'data-src', 'poster', 'srcset', 'data-srcset' ],
				} )
			}
		</script>

		<script>
			import 'lazysizes'
		</script>
	</body>
</html>
